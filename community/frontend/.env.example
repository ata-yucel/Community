# Bu dosyayı .env olarak kopyala:  cp .env.example .env
# <MAC-LAN-IP> yerine Mac'in yerel ağ IP'sini yaz. Bulmak için:  ipconfig getifaddr en0
# Telefon ve Mac AYNI Wi-Fi ağında olmalı.
# Değer değişince sunucuyu yeniden başlat: npx expo start -c
# (EXPO_PUBLIC_ değerleri derleme anında gömülür, çalışırken okunmaz.)
EXPO_PUBLIC_API_URL=http://<MAC-LAN-IP>/api
