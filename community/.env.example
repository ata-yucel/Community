# Bu dosyayı `.env` olarak kopyala ve değerleri değiştir:  cp .env.example .env
# .env dosyası git'e GİRMEZ (.gitignore'da).

# --- Postgres ---
POSTGRES_USER=appuser
POSTGRES_PASSWORD=change_me_strong_pw
# Servis başına bir database (virgülle ayrılmış, boşluksuz):
POSTGRES_MULTIPLE_DATABASES=auth_db,profile_db,social_db,chat_db

# --- RabbitMQ ---
RABBITMQ_USER=appuser
RABBITMQ_PASSWORD=change_me_strong_pw

# --- MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_strong_pw

# --- Auth service ---
# Üret:  openssl rand -hex 32
JWT_SECRET=replace_with_a_long_random_string
